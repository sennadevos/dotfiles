#!/bin/bash
set -euo pipefail

THEMES_DIR="$HOME/Pictures/Wallpapers/themes"

usage() {
    echo "Usage: wallpaper-create <source-image> <theme-name>"
    echo ""
    echo "Slices a source image into per-monitor wallpapers based on your"
    echo "current niri output layout. The slices are saved as a named theme."
    exit 1
}

[[ $# -lt 2 ]] && usage

SOURCE="$1"
THEME="$2"
THEME_DIR="$THEMES_DIR/$THEME"

if [[ ! -f "$SOURCE" ]]; then
    echo "Error: source image '$SOURCE' not found"
    exit 1
fi

if [[ -d "$THEME_DIR" ]]; then
    echo "Theme '$THEME' already exists. Overwrite? [y/N]"
    read -r answer
    [[ "$answer" != "y" && "$answer" != "Y" ]] && exit 0
fi

mkdir -p "$THEME_DIR"
cp "$SOURCE" "$THEME_DIR/source${SOURCE##*\.}"

# Read active outputs sorted by x position (left to right)
# Uses Logical size which already accounts for rotation
# Format: name width height x y
monitor_specs=()
total_width=0
max_height=0
while IFS= read -r line; do
    read -r name w h px py <<< "$line"
    monitor_specs+=("$name $w $h $px $py")
    total_width=$((total_width + w))
    if (( h > max_height )); then
        max_height=$h
    fi
done < <(
    niri msg outputs | awk '
    /^Output/ {
        name = $NF
        gsub(/["()]/, "", name)
    }
    /Logical position:/ {
        gsub(/,/, "", $3)
        gsub(/,/, "", $4)
        px = $3; py = $4
    }
    /Logical size:/ {
        split($3, res, "x")
        w = res[1]; h = res[2]
        print name, w, h, px, py
    }
    ' | sort -k4 -n
)

echo ""
echo "Wallpaper slices needed:"
echo "  Total width: ${total_width}px, Max height: ${max_height}px"
for m in "${monitor_specs[@]}"; do
    read -r name ww wh px py <<< "$m"
    echo "  $name: ${ww}x${wh}"
done

# Get source image dimensions
src_info=$(magick identify -format "%w %h" "$SOURCE")
read -r src_w src_h <<< "$src_info"
echo ""
echo "Source image: ${src_w}x${src_h}"

# Scale strategy: make the image cover total_width x max_height
# Scale so that both dimensions are at least the target
scale_w=$(echo "scale=6; $total_width / $src_w" | bc)
scale_h=$(echo "scale=6; $max_height / $src_h" | bc)

# Use the larger scale factor to ensure full coverage
if (( $(echo "$scale_w > $scale_h" | bc -l) )); then
    scale=$scale_w
else
    scale=$scale_h
fi

scaled_w=$(echo "$src_w * $scale" | bc | cut -d. -f1)
scaled_h=$(echo "$src_h * $scale" | bc | cut -d. -f1)

echo "Scaling to: ${scaled_w}x${scaled_h} (factor: $scale)"

# Scale the source
magick "$SOURCE" -resize "${scaled_w}x${scaled_h}!" -quality 95 /tmp/wallpaper-scaled.png

# Center-crop to exactly total_width x max_height
offset_x=$(( (scaled_w - total_width) / 2 ))
offset_y=$(( (scaled_h - max_height) / 2 ))
# Clamp to 0
(( offset_x < 0 )) && offset_x=0
(( offset_y < 0 )) && offset_y=0

magick /tmp/wallpaper-scaled.png -crop "${total_width}x${max_height}+${offset_x}+${offset_y}" +repage /tmp/wallpaper-canvas.png

echo "Cropped canvas: ${total_width}x${max_height}"

# Slice for each monitor
x_offset=0
for m in "${monitor_specs[@]}"; do
    read -r name ww wh px py <<< "$m"

    # Vertical center for this monitor's height
    y_off=$(( (max_height - wh) / 2 ))
    (( y_off < 0 )) && y_off=0

    outfile="$THEME_DIR/$name.jpg"
    magick /tmp/wallpaper-canvas.png -crop "${ww}x${wh}+${x_offset}+${y_off}" +repage -quality 95 "$outfile"

    actual=$(magick identify -format "%wx%h" "$outfile")
    echo "  $name: ${ww}x${wh} -> $outfile ($actual)"

    x_offset=$((x_offset + ww))
done

# Clean up temp files
rm -f /tmp/wallpaper-scaled.png /tmp/wallpaper-canvas.png

echo ""
echo "Theme '$THEME' created at $THEME_DIR"
echo "Apply with: wallpaper-set $THEME"
